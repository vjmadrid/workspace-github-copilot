{
	"inputs": [
		{
			"type": "promptString",
			"id": "github_token",
			"description": "GitHub Personal Access Token",
			"password": true
		}
	],
	"servers": {
		"github-mcp-with-node": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-github"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "xxx"
			},
			"type": "stdio"
		},
		"github": {
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN",
				"ghcr.io/github/github-mcp-server"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
			},
			"type": "stdio"
		},
		"github-2": {
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"--env-file",
				"/path/.mcp/.env",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN",
				"-e",
				"GITHUB_HOST",
				"ghcr.io/github/github-mcp-server"
			],
			"env": {},
			"type": "stdio"
		},
		"mcp-atlassian": {
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"--env-file",
				"/path/.mcp/.env",
				"-e",
				"JIRA_URL",
				"-e",
				"JIRA_PERSONAL_TOKEN",
				"-e",
				"READ_ONLY_MODE=true",
				"-e",
				"JIRA_SSL_VERIFY=false",
				"-e",
				"MCP_VERBOSE=true",
				"ghcr.io/sooperset/mcp-atlassian:latest"
			],
			"env": {},
			"type": "stdio"
		}
	}
}